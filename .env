# Dataverse Container Configuration
# This file contains environment variables for customizing your Dataverse installation

# ========================
# Version Configuration
# ========================
DATAVERSE_VERSION=latest
CONFIGBAKER_VERSION=latest
POSTGRES_VERSION=16
SOLR_VERSION=9.6.1
MAILDEV_VERSION=2.1.0
PREVIEWERS_VERSION=latest
NGINX_VERSION=alpine

# ========================
# Database Configuration
# ========================
DATAVERSE_DB_USER=dataverse
DATAVERSE_DB_PASSWORD=secret
# WARNING: Change the password above for production use!

# ========================
# Port Configuration
# ========================
# API Gateway (Single Entry Point)
API_GATEWAY_PORT=80
API_GATEWAY_HTTPS_PORT=443

# MailDev Web UI (accessible via API Gateway at /maildev)
MAILDEV_WEB_PORT=1080

# Note: Individual services (PostgreSQL, Solr, Dataverse) are NOT exposed directly
# All traffic flows through the API Gateway for security and load balancing

# ========================
# Application Configuration
# ========================
# Base URL for your Dataverse installation
DATAVERSE_URL=http://localhost:8080

# System email address
DATAVERSE_MAIL_SYSTEM_EMAIL=dataverse@localhost

# ========================
# Bootstrap Configuration
# ========================
# Bootstrap mode: 'dev' for development, 'demo' for production-like setup
# dev = less secure but easier for development
# demo = more secure, requires unblock key for admin API
BOOTSTRAP_MODE=dev

# Bootstrap timeout (how long to wait for services to be ready)
BOOTSTRAP_TIMEOUT=10m

# ========================
# Feature Flags
# ========================
DATAVERSE_FEATURE_API_BEARER_AUTH=1

# ========================
# Advanced Configuration
# ========================
# Uncomment and modify these for advanced configurations

# Custom storage driver configuration
# JVM_ARGS_EXTRA=-Ddataverse.custom.setting=value
