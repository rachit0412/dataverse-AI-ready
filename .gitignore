# ============================================================================
secrets/
*.key
*.pem
*.p12
*.crt
*.csr
*.pfx

# Environment files with potential secrets
.env
.env.local
.env.*.local

# Secret summaries and reports
*SECRET*.txt
*PASSWORD*.txt
*CREDENTIALS*.txt

# ============================================================================
# Docker & Container Files
# ============================================================================

# Data volumes
data/
volumes/

# Docker Compose overrides
docker-compose.override.yml
docker-compose.local.yml

# Container logs
*.log
logs/

# ============================================================================
# Backup Files
# ============================================================================
backups/
*.sql
*.dump
*.backup
*.bak

# ============================================================================
