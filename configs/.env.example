# Dataverse Environment Configuration Template
# Copy this file to .env and customize with your values
# WARNING: Never commit .env to version control (protected by .gitignore)

# ============================================================================
# DATAVERSE VERSION
# ============================================================================
# Image versions - use specific tags for production
DATAVERSE_VERSION=latest
POSTGRES_VERSION=13
SOLR_VERSION=9.3.0
CONFIGBAKER_VERSION=latest
MAILDEV_VERSION=latest

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL credentials
# SECURITY: Generate strong random passwords for production
# Example: openssl rand -base64 32
POSTGRES_USER=dataverse
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dataverse

# Password requirements:
# - Minimum 16 characters for production
# - Mix of uppercase, lowercase, numbers, symbols
# - No dictionary words
# - Use password generator: pwsh -c "-join ((48..57) + (65..90) + (97..122) + (33..47) | Get-Random -Count 24 | % {[char]$_})"

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Public URL for Dataverse (change for production)
DATAVERSE_URL=http://localhost:8080

# Port to expose Dataverse web UI (default: 8080)
# Change if port 8080 is already in use
DATAVERSE_PORT=8080

# Bootstrap timeout (increase if bootstrap fails)
# Options: 3m, 5m, 10m, 15m
BOOTSTRAP_TIMEOUT=5m

# ============================================================================
# DEMO MODE CONFIGURATION (Optional)
# ============================================================================
# For demo mode, create configs/demo/init.sh with unblock key
# Then change bootstrap command in compose.yml to use 'demo' instead of 'dev'
# See: docs/SECURITY.md for demo mode setup

# ============================================================================
# ADVANCED CONFIGURATION (Optional)
# ============================================================================

# JVM Memory Settings
# Adjust based on available RAM (container gets these limits)
# Default: -Xmx2g -Xms1g
# For 16GB+ systems: -Xmx4g -Xms2g
# JVM_ARGS=-Xmx2g -Xms1g

# Email Configuration (for production SMTP)
# Default uses MailDev for testing
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@example.com

# DOI/Handle Configuration (for persistent identifiers)
# See: https://guides.dataverse.org/en/latest/installation/config.html#doi
# DOI_PROVIDER=datacite
# DOI_USERNAME=
# DOI_PASSWORD=
# DOI_PREFIX=10.5072

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. This .env file contains sensitive credentials - NEVER commit to git
# 2. Change default passwords before exposing to network
# 3. Use demo mode (not dev mode) for anything beyond localhost testing
# 4. For production, add HTTPS reverse proxy (nginx/Caddy)
# 5. Review docs/SECURITY.md for full security checklist

# ============================================================================
# VALIDATION
# ============================================================================
# After editing, validate with:
#   docker compose config
# 
# Should complete without errors and show merged configuration
